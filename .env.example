# OpenAI-compatible endpoint configuration
SUN_API_KEY=sk-your-key-here
SUN_BASE_URL=https://api.openai.com/v1
SUN_MODEL=gpt-4o-mini

# Agent loop
SUN_MAX_TURNS=25
SUN_TEMPERATURE=0.0
SUN_MAX_RETRIES=4

# Tool execution
SUN_SHELL_TIMEOUT=60
SUN_MAX_OUTPUT_CHARS=8000

# Safety
SUN_REQUIRE_CONFIRMATION=true
